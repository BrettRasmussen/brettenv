{
  "title": "Function Keys",
  "rules": [
    {
      "description": "F1-F12 and PC extra keys: Bare = Media (M1 style), Fn (Pause) = Standard",
      "manipulators": [
        {
          "type": "basic",
          "from": { "key_code": "f1", "modifiers": { "mandatory": ["fn"], "optional": ["any"] } },
          "to": [{ "key_code": "f1" }]
        },
        {
          "type": "basic",
          "from": { "key_code": "f1", "modifiers": { "optional": ["any"] } },
          "to": [{ "consumer_key_code": "display_brightness_decrement" }]
        },
        {
          "type": "basic",
          "from": { "key_code": "f2", "modifiers": { "mandatory": ["fn"], "optional": ["any"] } },
          "to": [{ "key_code": "f2" }]
        },
        {
          "type": "basic",
          "from": { "key_code": "f2", "modifiers": { "optional": ["any"] } },
          "to": [{ "consumer_key_code": "display_brightness_increment" }]
        },
        {
          "type": "basic",
          "from": { "key_code": "f3", "modifiers": { "mandatory": ["fn"], "optional": ["any"] } },
          "to": [{ "key_code": "f3" }]
        },
        {
          "type": "basic",
          "from": { "key_code": "f3", "modifiers": { "optional": ["any"] } },
          "to": [{ "key_code": "mission_control" }]
        },
        {
          "type": "basic",
          "from": { "key_code": "f4", "modifiers": { "mandatory": ["fn"], "optional": ["any"] } },
          "to": [{ "key_code": "f4" }]
        },
        {
          "type": "basic",
          "from": { "key_code": "f4", "modifiers": { "optional": ["any"] } },
          "to": [{ "key_code": "spotlight" }]
        },
        {
          "type": "basic",
          "from": { "key_code": "f5", "modifiers": { "mandatory": ["fn"], "optional": ["any"] } },
          "to": [{ "key_code": "f5" }]
        },
        {
          "type": "basic",
          "from": { "key_code": "f5", "modifiers": { "optional": ["any"] } },
          "to": [{ "key_code": "dictation" }]
        },
        {
          "type": "basic",
          "from": { "key_code": "f6", "modifiers": { "mandatory": ["fn"], "optional": ["any"] } },
          "to": [{ "key_code": "f6" }]
        },
        {
          "type": "basic",
          "from": { "key_code": "f6", "modifiers": { "optional": ["any"] } },
          "to": [{ "key_code": "f6" }]
        },
        {
          "type": "basic",
          "from": { "key_code": "f7", "modifiers": { "mandatory": ["fn"], "optional": ["any"] } },
          "to": [{ "key_code": "f7" }]
        },
        {
          "type": "basic",
          "from": { "key_code": "f7", "modifiers": { "optional": ["any"] } },
          "to": [{ "consumer_key_code": "scan_previous_track" }]
        },
        {
          "type": "basic",
          "from": { "key_code": "f8", "modifiers": { "mandatory": ["fn"], "optional": ["any"] } },
          "to": [{ "key_code": "f8" }]
        },
        {
          "type": "basic",
          "from": { "key_code": "f8", "modifiers": { "optional": ["any"] } },
          "to": [{ "consumer_key_code": "play_or_pause" }]
        },
        {
          "type": "basic",
          "from": { "key_code": "f9", "modifiers": { "mandatory": ["fn"], "optional": ["any"] } },
          "to": [{ "key_code": "f9" }]
        },
        {
          "type": "basic",
          "from": { "key_code": "f9", "modifiers": { "optional": ["any"] } },
          "to": [{ "consumer_key_code": "scan_next_track" }]
        },
        {
          "type": "basic",
          "from": { "key_code": "f10", "modifiers": { "mandatory": ["fn"], "optional": ["any"] } },
          "to": [{ "key_code": "f10" }]
        },
        {
          "type": "basic",
          "from": { "key_code": "f10", "modifiers": { "optional": ["any"] } },
          "to": [{ "consumer_key_code": "mute" }]
        },
        {
          "type": "basic",
          "from": { "key_code": "f11", "modifiers": { "mandatory": ["fn"], "optional": ["any"] } },
          "to": [{ "key_code": "f11" }]
        },
        {
          "type": "basic",
          "from": { "key_code": "f11", "modifiers": { "optional": ["any"] } },
          "to": [{ "consumer_key_code": "volume_decrement" }]
        },
        {
          "type": "basic",
          "from": { "key_code": "f12", "modifiers": { "mandatory": ["fn"], "optional": ["any"] } },
          "to": [{ "key_code": "f12" }]
        },
        {
          "type": "basic",
          "from": { "key_code": "f12", "modifiers": { "optional": ["any"] } },
          "to": [{ "consumer_key_code": "volume_increment" }]
        },
        {
          "type": "basic",
          "from": { "key_code": "print_screen", "modifiers": { "mandatory": ["fn"], "optional": ["any"] } },
          "to": [{ "key_code": "f13" }]
        },
        {
          "type": "basic",
          "from": { "key_code": "print_screen", "modifiers": { "optional": ["any"] } },
          "to": [
            {
              "shell_command": "osascript -e 'set volume input volume (if (input volume of (get volume settings) is 0) then 100 else 0)'"
            }
          ]
        },
        {
          "type": "basic",
          "from": { "key_code": "scroll_lock", "modifiers": { "mandatory": ["fn"], "optional": ["any"] } },
          "to": [{ "key_code": "f14" }]
        },
        {
          "type": "basic",
          "from": { "key_code": "scroll_lock", "modifiers": { "optional": ["any"] } },
          "to": [{ "key_code": "q", "modifiers": ["left_command", "left_control"] }]
        },
        {
          "type": "basic",
          "from": { "key_code": "pause", "modifiers": { "optional": ["any"] } },
          "to": [{ "apple_vendor_top_case_key_code": "keyboard_fn" }]
        }
      ]
    }
  ]
}
