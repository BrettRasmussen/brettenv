{
  "title": "App Launchers",
  "rules": [
    {
      "description": "Brave browser cmd+opt+b",
      "manipulators": [
        {
          "type": "basic",
          "from": {
            "key_code": "b",
            "modifiers": {
              "mandatory": [
                "command",
                "option"
              ],
              "optional": [
                "caps_lock"
              ]
            }
          },
          "to": [
            {
              "shell_command": "open -a 'Brave Browser.app'"
            }
          ],
          "conditions": [
            {
              "type": "frontmost_application_unless",
              "bundle_identifiers": [
                "^com\\.brave\\.Browser$"
              ]
            }
          ]
        }
      ]
    },
