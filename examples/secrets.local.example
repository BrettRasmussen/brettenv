# Template for ~/.secrets.local
# Copy this file to ~/.secrets.local and fill in your secrets.
# This file is sourced by zshrc.main and should NOT be committed to the repo.

# export EMAIL="your_email@example.com"
# export GITHUB_TOKEN="your_token_here"

# Database / Work specific
# export DB_USERNAME="your_username"
# export DB_PASSWORD="your_password"
# export KEEP_COMPANIES="27,31,61"
