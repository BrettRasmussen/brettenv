#!/usr/bin/env zsh

show_help () {
echo "
  hrc: heroku rails console. Launches a rails console with vi editing mode
  enabled on a heroku app. Passes any arguments to the 'heroku' command, so you
  can provide '--app', etc.

  Usage:
    $ hrc [heroku_options]
"
exit
}

# Show help if the user passed '-h' as the first argument, or if no arguments were provided.
if [[ "$1" == "-h" ]] || [[ $# -eq 0 ]]; then
  show_help
fi

exec heroku run bash "-i -c 'echo \"set editing-mode vi\" > ~/.inputrc; rails console'" "$@"
